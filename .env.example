# ──────────────────────────────────────────────────────────────
# Zeylo Dashboard — environment variables
# Copy this file to `.env` and adjust values before deploying.
# NEVER commit the real .env file.
# ──────────────────────────────────────────────────────────────

# ---- General ----
NODE_ENV=production

# ---- PostgreSQL ----
# IMPORTANT: the password is embedded in DATABASE_URL below. Use ONLY
# URL-safe characters (letters + digits). Avoid / : @ + # ? & % and spaces,
# otherwise Prisma fails with "P1013: invalid port number in database URL".
# Generate a safe one with:  openssl rand -hex 24
POSTGRES_USER=zeylo
POSTGRES_PASSWORD=change_me_alphanumeric_only
POSTGRES_DB=zeylo
# Internal connection string used by the backend (service name = postgres).
# The password here MUST match POSTGRES_PASSWORD exactly.
DATABASE_URL=postgresql://zeylo:change_me_alphanumeric_only@postgres:5432/zeylo?schema=public

# ---- Backend ----
# Port the NestJS server listens on (internal only)
BACKEND_PORT=3000
# Public origin(s) allowed by CORS, comma separated (your Dokploy domain)
CORS_ORIGINS=https://dashboard.zeylo.ciphera.ch,http://localhost:8080

# JWT — use long random strings, DIFFERENT for admin and client.
# Generate with: openssl rand -base64 48
JWT_ADMIN_ACCESS_SECRET=change_me_admin_access_secret
JWT_ADMIN_REFRESH_SECRET=change_me_admin_refresh_secret
JWT_CLIENT_ACCESS_SECRET=change_me_client_access_secret
JWT_CLIENT_REFRESH_SECRET=change_me_client_refresh_secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# ---- File storage (local Docker volume) ----
FILE_STORAGE_DIR=/app/storage
# Max upload size in bytes (default 25 MB)
MAX_UPLOAD_BYTES=26214400

# ---- Third-party integrations (stubbed — leave blank to run in mock mode) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# proxycheck.io — VPN/Proxy/Tor detection + provider (optional).
# Works without a key (100 lookups/day); a free key raises it to 1000/day.
PROXYCHECK_API_KEY=

# Outbound proxy used by the company-verification scraper (Moneyhouse /
# uid.admin.ch). Works with ANY HTTP/HTTPS proxy. Accepts a full URL, or
# "host:port" / "user:pass@host:port" (http:// is assumed if no scheme).
# Examples:
#   PROXY_URL=http://brd-customer-xxx-zone-yyy:password@brd.superproxy.io:33335
#   PROXY_URL=user:pass@proxy.example.com:8080
# If EMPTY: automatic company search is DISABLED (manual entry only).
PROXY_URL=

# ---- Public URLs (branded links / custom domains) ----
# Public URL of the dashboard (used to build temporary links by default)
PUBLIC_APP_URL=https://dashboard.ciphera.ch
# Hostname clients must CNAME their custom domain to (usually the host above)
PUBLIC_LINK_TARGET=dashboard.ciphera.ch

# ---- Frontend ----
# Host port exposed for Dokploy to attach the domain to (frontend nginx)
FRONTEND_PORT=8080
