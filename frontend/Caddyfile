# Caddy = single public entrypoint with automatic HTTPS.
# - Serves the SPA and proxies /api to the backend.
# - Issues a real Let's Encrypt certificate automatically for the dashboard
#   host AND every custom client domain (on-demand), gated by the backend so
#   only verified domains get a certificate.
{
	email {$ACME_EMAIL:admin@ciphera.ch}
	# Admin API (internal network only) — the backend provisions per-domain
	# certificates with each owner's email through it.
	admin 0.0.0.0:2019
	on_demand_tls {
		ask {$DOMAIN_ASK_URL:http://backend:3000/api/public/domain-allowed}
	}
}

# All HTTPS hosts (dashboard + custom domains). Certificate obtained on demand
# per hostname, authorized by the ask endpoint.
https:// {
	tls {
		on_demand
	}
	encode gzip zstd

	# API → backend (same origin /api)
	handle /api/* {
		reverse_proxy {$BACKEND_UPSTREAM:backend:3000}
	}

	# SPA (client-side routing)
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

# Redirect plain HTTP to HTTPS (also serves ACME HTTP-01 challenges).
http:// {
	redir https://{host}{uri} permanent
}
